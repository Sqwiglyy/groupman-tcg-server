{
  "name": "groupman-tcg-server",
  "version": "0.1.0",
  "private": true,
  "description": "Offline sync and group collection API for the Groupman TCG RuneLite plugin",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "db:migrate:local": "wrangler d1 migrations apply groupman-tcg --local",
    "db:migrate:remote": "wrangler d1 migrations apply groupman-tcg --remote",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260717.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "engines": {
    "node": ">=20"
  }
}

